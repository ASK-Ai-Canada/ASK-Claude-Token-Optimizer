# ASK-Token-Optimizer — environment configuration template
# Copy to `.env` and fill in your own values.

# Bind address for the optional semantic-compression daemon (service mode).
# Default to localhost; only expose externally behind your own auth proxy.
LISTEN_ADDR=127.0.0.1:8095

# Optional inference backend used by /v1/chat/clean compression rules.
# Point this at any OpenAI-compatible endpoint you control
# (vLLM, TGI, llama.cpp, Ollama, hosted via proxy). Leave blank to disable
# inference-mode compression — the optimizer still runs heuristic rules.
INFERENCE_URL=
INFERENCE_MODEL=

# Compression heuristics — tune to taste.
COMPRESS_THRESHOLD=2000
KEEP_RECENT=4
